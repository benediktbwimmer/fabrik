{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabrik.dev/schemas/workflow-definition.schema.json",
  "title": "Workflow Definition",
  "type": "object",
  "required": ["id", "version", "initial_state", "states"],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "initial_state": {
      "type": "string",
      "minLength": 1
    },
    "states": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "handler"],
            "properties": {
              "type": { "const": "step" },
              "handler": { "type": "string" },
              "next": { "type": ["string", "null"] },
              "retry": {
                "type": ["object", "null"],
                "required": ["max_attempts", "delay"],
                "properties": {
                  "max_attempts": { "type": "integer", "minimum": 1 },
                  "delay": { "type": "string" }
                },
                "additionalProperties": false
              },
              "config": {
                "type": ["object", "null"],
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["kind", "method", "url"],
                    "properties": {
                      "kind": { "const": "http_request" },
                      "method": { "type": "string", "minLength": 1 },
                      "url": { "type": "string", "minLength": 1 },
                      "headers": {
                        "type": "object",
                        "additionalProperties": { "type": "string" }
                      },
                      "body": true,
                      "body_from_input": { "type": "boolean" }
                    },
                    "additionalProperties": false
                  },
                  { "type": "null" }
                ]
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "event_type", "next"],
            "properties": {
              "type": { "const": "wait_for_event" },
              "event_type": { "type": "string" },
              "next": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "timer_ref", "next"],
            "properties": {
              "type": { "const": "wait_for_timer" },
              "timer_ref": { "type": "string" },
              "next": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "const": "succeed" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "const": "fail" }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
