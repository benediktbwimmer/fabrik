{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fabrik.dev/schemas/event-envelope.schema.json",
  "title": "Event Envelope",
  "type": "object",
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "occurred_at",
    "tenant_id",
    "definition_id",
    "definition_version",
    "artifact_hash",
    "instance_id",
    "run_id",
    "partition_key",
    "producer",
    "payload",
    "metadata"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "definition_id": {
      "type": "string",
      "minLength": 1
    },
    "definition_version": {
      "type": "integer",
      "minimum": 1
    },
    "artifact_hash": {
      "type": "string",
      "minLength": 1
    },
    "instance_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "partition_key": {
      "type": "string",
      "minLength": 1
    },
    "producer": {
      "type": "string",
      "minLength": 1
    },
    "causation_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "correlation_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "dedupe_key": {
      "type": [
        "string",
        "null"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "payload": true
  },
  "additionalProperties": false
}
